# Copy this file to .env.local and fill in the values.

# ── Neon Database (Postgres) ─────────────────────────────────────────────────
# Create a database at https://console.neon.tech and copy the connection string
DATABASE_URL=

# ── Upstash Redis (storage) ──────────────────────────────────────────────────
# Create a database at https://console.upstash.com, then copy the REST API values.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Google Chat ─────────────────────────────────────────────────────────────
# Webhook URL for sending field notes to a Google Chat space
GOOGLE_CHAT_WEBHOOK_URL=

# ── API Key (Layer 1 — endpoint abuse protection) ───────────────────────────
# Both variables must be set to the SAME random hex string.
# Server-only version (used inside API route handlers to verify incoming requests)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_NOTES_API_KEY=

# Client-exposed version (sent as the x-api-key request header from the browser)
NEXT_PUBLIC_FIELD_NOTES_API_KEY=

# ── Session Secret (for iron-session) ───────────────────────────────────────
# A random string used to encrypt session cookies (min 32 characters recommended)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Public Base URL ──────────────────────────────────────────────────────────
# Used to generate photo URLs for Google Chat
# For production: https://your-app-name.vercel.app
# For development: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# ── Google Translate (bilingual voice dictation) ─────────────────────────────
# Used by the dual-recognition voice dictation feature to translate Spanish → English.
# Must be NEXT_PUBLIC_ so the browser can call the REST API directly (no server hop needed).
# Get a key at https://console.cloud.google.com → APIs & Services → Cloud Translation API.
NEXT_PUBLIC_GOOGLE_TRANSLATE_API_KEY=


